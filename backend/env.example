# Copy to .env and fill in values. Do not commit .env.

# Tuya (required for backend startup)
TUYA_ACCESS_ID=
TUYA_ACCESS_SECRET=
TUYA_ENDPOINT=https://openapi.tuyaeu.com
TUYA_DEVICE_IDS=

# Database
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=smarthub
DB_PORT=5432

# Scene device IDs (comma-separated)
AWAY_DEVICE_IDS=bf764156746c04629ds53u,bf7e312cdc1833bcd1vtwq,bf5267cc9a40db55fdewu1
SLEEP_EXTRA_DEVICE_IDS=bf1b3f05e130f44ea0sy5w,bf1cd69a2f640b4d5ewslp,bf6b932ae27f7f2edeycd6

# Server
PORT=3001

# Optional: OpenAI for /ai/howto
# OPENAI_API_KEY=

# Frontend (optional; defaults to http://127.0.0.1:3001)
# NEXT_PUBLIC_API_BASE=http://127.0.0.1:3001
